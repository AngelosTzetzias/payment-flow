# Backend environment. Copy to .env and fill in.

# Postgres (matches docker-compose.yml)
DATABASE_URL="postgresql://payment:payment@localhost:5432/payment_flow?schema=public"

PORT=3001

# Public base URL of the Next.js customer checkout (used to build checkout links)
CHECKOUT_BASE_URL="http://localhost:3000"

# Stage 1 mock settlement: delay (ms) for the pending->authorizing->paid walk.
# Defaults to 2000 if unset. Removed in Stage 2 when real TrueLayer PIS lands.
MOCK_SETTLE_DELAY_MS=2000

# Auth (Stage 1)
JWT_SECRET="change-me-in-prod"
JWT_EXPIRES_IN="7d"

# Encryption (Stage 1): 32-byte key for merchant bank PII, as 64 hex chars.
# Generate with: openssl rand -hex 32
PII_ENCRYPTION_KEY=""

# TrueLayer (Stage 2 sandbox -> Stage 5 live). Leave blank until Stage 2.
TRUELAYER_ENV="sandbox"
TRUELAYER_CLIENT_ID=""
TRUELAYER_CLIENT_SECRET=""
TRUELAYER_WEBHOOK_SECRET=""
REDIRECT_URI="http://localhost:3000/p"
